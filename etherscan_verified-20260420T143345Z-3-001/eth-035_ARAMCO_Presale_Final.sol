// File: Presale_Final.sol


pragma solidity ^0.8.20;








contract ARAMCO_Presale_Final is Ownable, ReentrancyGuard, Pausable {
    using SafeERC20 for IERC20;

    struct Stage {
        uint256 price;       // USD price per whole token (1e18)
        uint256 supplyLimit; // Max tokens for this stage
        uint256 sold;        // Tokens sold in this stage
    }

    struct PaymentToken {
        bool isAllowed;
        address priceFeed;
        uint256 scalingFactor; // 10 ** (18 - decimals)
        uint256 oracleScalingFactor; // 10 ** oracleDecimals
        uint256 heartbeat;
    }

    // --- Constants ---
    uint256 public constant STAGE_COUNT = 6;
    uint256 public constant TOKENS_PER_STAGE = 250_000_000 * 1e18;
    uint256 public constant PRECISION = 1e18;
    
    uint256 public constant MIN_TX_USD = 20 * 1e18; 
    uint256 public constant MAX_WALLET_TOKENS = 300_000_000 * 1e18;
    uint256 public constant REFERRAL_BONUS_BPS = 500; 
    uint256 public constant MIN_HEARTBEAT = 1 hours;

    // --- State Variables ---
    Stage[STAGE_COUNT] public stages;
    uint8 public currentStageIndex;
    
    address public presaleToken;
    address public treasuryWallet;
    
    uint256 public totalObligation; 
    bool public isInitialized;

    mapping(address => uint256) public purchasedTokens;
    mapping(address => PaymentToken) public allowedStables;
    
    address public nativePriceFeed;
    uint256 public nativeOracleScalingFactor;
    uint256 public nativeHeartbeat;

    // New storage for stage‑level purchase data (required by vesting)
    mapping(address => uint8[]) private _userStages;                     // stages the user participated in
    mapping(address => mapping(uint8 => uint256)) public stagePurchases; // tokens bought per stage

    // --- Events ---
    event TokensPurchased(address indexed buyer, uint256 amount, uint256 usdValue);
    event ReferralBonus(address indexed referrer, uint256 amount);
    event ReferralBonusSkipped(address indexed referrer, uint256 amount, string reason);
    event StablecoinToggled(address indexed token, bool status);
    event PresaleTokenSet(address indexed token);
    event NativeFeedUpdated(address indexed feed, uint256 heartbeat);
    event TreasuryUpdated(address indexed newTreasury);

    constructor(address _nativePriceFeed, uint256 _heartbeat, address _multisig) Ownable(msg.sender) {
        require(_nativePriceFeed != address(0) && _multisig != address(0), "Zero address");
        require(_heartbeat >= MIN_HEARTBEAT, "Heartbeat low");

        nativePriceFeed = _nativePriceFeed;
        nativeHeartbeat = _heartbeat;
        treasuryWallet = _multisig;
        nativeOracleScalingFactor = 10 ** AggregatorV3Interface(_nativePriceFeed).decimals();

        // By casting the first element to uint256, we force the whole array to be uint256[6]
        uint256[6] memory prices = [
            uint256(5000 * 10**12), // Stage 0:  $0.00500
            12500 * 10**12,          // Stage 1: $0.01250
            20000 * 10**12,          // Stage 2: $0.02000
            27500 * 10**12,         // Stage 3: $0.027500
            35000 * 10**12,         // Stage 4: $0.035000
            42500 * 10**12          // Stage 5: $0.042500
        ];

        for (uint8 i; i < STAGE_COUNT; i++) {
            stages[i].price = prices[i];
            stages[i].supplyLimit = TOKENS_PER_STAGE;
        }
    }

    /* ========== PURCHASE LOGIC ========== */

    function buyWithNative(address _referrer) external payable whenNotPaused nonReentrant {
        require(isInitialized, "Not active");
        uint256 usdValue = _getOracleUSD(msg.value, nativePriceFeed, nativeHeartbeat, nativeOracleScalingFactor);
        require(usdValue >= MIN_TX_USD, "Below min");

        (bool success, ) = payable(treasuryWallet).call{value: msg.value}("");
        require(success, "Treasury fail");

        _allocateTokens(msg.sender, usdValue, _referrer);
    }

    function buyWithStable(address token, uint256 amount, address _referrer) external whenNotPaused nonReentrant {
        require(isInitialized, "Not active");
        PaymentToken memory pt = allowedStables[token];
        require(pt.isAllowed, "Unsupported");

        IERC20(token).safeTransferFrom(msg.sender, treasuryWallet, amount);

        uint256 amount18 = amount * pt.scalingFactor;
        uint256 usdValue = (pt.priceFeed == address(0)) 
            ? amount18 
            : _getOracleUSD(amount18, pt.priceFeed, pt.heartbeat, pt.oracleScalingFactor);

        require(usdValue >= MIN_TX_USD, "Below min");
        _allocateTokens(msg.sender, usdValue, _referrer);
    }

    /**
     * @dev Refined Spillover Logic to prevent remainder dust loss.
     *      Now records per‑stage purchases for vesting.
     */
    function _allocateTokens(address buyer, uint256 usdAmount, address referrer) internal {
        uint256 remainingUsd = usdAmount;
        uint256 totalTokensToGive = 0;

        while (remainingUsd > 0 && currentStageIndex < STAGE_COUNT) {
            Stage storage stage = stages[currentStageIndex];
            uint256 stageAvailable = stage.supplyLimit - stage.sold;
            uint256 potentialTokens = (remainingUsd * PRECISION) / stage.price;

            if (potentialTokens == 0) break; // Cannot buy even the smallest unit

            if (potentialTokens <= stageAvailable) {
                // Full purchase fits in current stage
                stage.sold += potentialTokens;
                totalTokensToGive += potentialTokens;
                uint256 usdUsed = (potentialTokens * stage.price) / PRECISION;
                remainingUsd = (remainingUsd > usdUsed) ? remainingUsd - usdUsed : 0;

                // Record stage purchase
                if (stagePurchases[buyer][currentStageIndex] == 0) {
                    _userStages[buyer].push(currentStageIndex);
                }
                stagePurchases[buyer][currentStageIndex] += potentialTokens;

                break; 
            } else {
                // Partially fills current stage, move to next
                totalTokensToGive += stageAvailable;
                uint256 usdUsed = (stageAvailable * stage.price) / PRECISION;
                stage.sold = stage.supplyLimit;
                remainingUsd = (remainingUsd > usdUsed) ? remainingUsd - usdUsed : 0;

                // Record stage purchase
                if (stagePurchases[buyer][currentStageIndex] == 0) {
                    _userStages[buyer].push(currentStageIndex);
                }
                stagePurchases[buyer][currentStageIndex] += stageAvailable;

                currentStageIndex++; 
            }
        }

        require(currentStageIndex < STAGE_COUNT || remainingUsd == 0, "Hard cap");
        require(purchasedTokens[buyer] + totalTokensToGive <= MAX_WALLET_TOKENS, "Limit");

        if (referrer != address(0) && referrer != buyer) {
            uint256 bonus = (totalTokensToGive * REFERRAL_BONUS_BPS) / 10000;
            if (purchasedTokens[referrer] + bonus <= MAX_WALLET_TOKENS) {
                purchasedTokens[referrer] += bonus;
                totalObligation += bonus;
                emit ReferralBonus(referrer, bonus);
            } else {
                emit ReferralBonusSkipped(referrer, bonus, "Cap exceeded");
            }
        }

        purchasedTokens[buyer] += totalTokensToGive;
        totalObligation += totalTokensToGive;
        emit TokensPurchased(buyer, totalTokensToGive, usdAmount);
    }

    /* ========== ADMIN & VIEW ========== */

    function setPresaleToken(address _token) external onlyOwner {
        require(_token != address(0), "Zero address");
        require(presaleToken == address(0), "Already set");
        presaleToken = _token;
        emit PresaleTokenSet(_token);
    }

    function addStablecoin(address token, address priceFeed, uint256 heartbeat) external onlyOwner {
        require(token != address(0), "Zero address");
        uint8 dec = IERC20Metadata(token).decimals();
        require(dec <= 18, "Decimals > 18");
        
        uint256 oracleScale = 0;
        if (priceFeed != address(0)) {
            require(heartbeat >= MIN_HEARTBEAT, "Heartbeat low");
            oracleScale = 10 ** AggregatorV3Interface(priceFeed).decimals();
        }

        allowedStables[token] = PaymentToken({
            isAllowed: true,
            priceFeed: priceFeed,
            scalingFactor: 10 ** (18 - dec),
            oracleScalingFactor: oracleScale,
            heartbeat: heartbeat
        });
        emit StablecoinToggled(token, true);
    }

    function toggleStablecoin(address token, bool status) external onlyOwner {
        allowedStables[token].isAllowed = status;
        emit StablecoinToggled(token, status);
    }

    function updateNativeFeed(address _feed, uint256 _heartbeat) external onlyOwner {
        require(_feed != address(0), "Zero address");
        require(_heartbeat >= MIN_HEARTBEAT, "Heartbeat low");
        nativePriceFeed = _feed;
        nativeHeartbeat = _heartbeat;
        nativeOracleScalingFactor = 10 ** AggregatorV3Interface(_feed).decimals();
        emit NativeFeedUpdated(_feed, _heartbeat);
    }

    function updateTreasury(address _newTreasury) external onlyOwner {
        require(_newTreasury != address(0), "Zero address");
        treasuryWallet = _newTreasury;
        emit TreasuryUpdated(_newTreasury);
    }

    function pause() external onlyOwner { _pause(); }
    function unpause() external onlyOwner { _unpause(); }
    function initPresale() external onlyOwner { isInitialized = true; }

    // --- Getters required by the vesting contract ---
    function getUserStages(address user) external view returns (uint8[] memory) {
        return _userStages[user];
    }

    // stagePurchases is already public via the mapping

    function _getOracleUSD(uint256 amt18, address feed, uint256 hb, uint256 scale) internal view returns (uint256) {
        (, int256 price,, uint256 upd,) = AggregatorV3Interface(feed).latestRoundData();
        require(price > 0 && upd >= block.timestamp - hb, "Oracle stale");
        return (amt18 * uint256(price)) / scale;
    }

    receive() external payable { revert("Use buyWithNative"); }
}