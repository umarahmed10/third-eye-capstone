# VITE_API_URL selects where the frontend sends API requests.
#
# Local dev: leave this UNSET. Vite's dev server proxies "/api" straight to the
# local backend (see vite.config.ts), so the default `const API = "/api"` in
# App.tsx just works.
#
# Vercel deployment: set this to the full Render backend URL, including the
# "/api" suffix it expects, e.g.:
#   VITE_API_URL=https://thirdeye-backend.onrender.com/api
VITE_API_URL=
