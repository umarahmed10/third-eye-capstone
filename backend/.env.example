# LLM_BACKEND selects which engine services/llm.py talks to:
#   "ollama" (default) - local-dev mode, talks to a local Ollama server below.
#   "groq"             - deployed/demo mode, talks to Groq's hosted free-tier API.
LLM_BACKEND=ollama

# --- ollama mode (local dev) ---
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT=300

# --- groq mode (deployed demo) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- council mode (services/council.py) ---
# Only needed when running the council baseline with --llm-backend groq —
# one of the three specialists runs on Cerebras instead of Groq for genuine
# model/provider diversity (Ollama mode uses two different local models
# instead and doesn't need this). Get a free key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# DATABASE_URL selects the persistence backend in db.py:
#   unset (default) - local-dev mode, uses SQLite (backend/thirdeye.db).
#   set             - deployed mode, uses Postgres via asyncpg (e.g. a Neon connection string).
DATABASE_URL=

# ENABLE_VECTORDB toggles the ChromaDB similarity-search layer.
# Default true for local dev; set to "false" in deployment (see services/vectordb.py).
ENABLE_VECTORDB=true

# Comma-separated list of allowed CORS origins for the frontend.
ALLOWED_ORIGINS=http://localhost:5173
